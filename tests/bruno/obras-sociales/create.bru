meta {
  name: create
  type: http
  seq: 3
}

post {
  url: {{base_url}}/obras-sociales
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token_admin}}
}

body:json {
  {
    "nombre": "OSDE {{$timestamp}}",
    "descripcion": "Obra social OSDE",
    "porcentaje_descuento": 15.00,
    "es_particular": 0
  }
}

settings {
  encodeUrl: true
}
