meta {
  name: registrarPaciente
  type: http
  seq: 1
}

post {
  url: {{base_url}}/usuarios/pacientes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token_admin}}
}

body:json {
  {
    "documento": "{{$timestamp}}",
    "apellido": "Test",
    "nombres": "Paciente",
    "email": "paciente{{$timestamp}}@test.com",
    "contrasenia": "test123",
    "id_obra_social": 1
  }
}

settings {
  encodeUrl: true
}
