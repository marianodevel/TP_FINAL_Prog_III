meta {
  name: registrarMedico
  type: http
  seq: 2
}

post {
  url: {{base_url}}/usuarios/medicos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token_admin}}
}

body:json {
  {
    "documento": "9{{$timestamp}}",
    "apellido": "Test",
    "nombres": "Medico",
    "email": "medico{{$timestamp}}@test.com",
    "contrasenia": "test123",
    "id_especialidad": 1,
    "matricula": {{$timestamp}},
    "descripcion": "Médico de prueba",
    "valor_consulta": 5000.00
  }
}

settings {
  encodeUrl: true
}
