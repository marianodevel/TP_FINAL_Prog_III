meta {
  name: registrarAdmin
  type: http
  seq: 3
}

post {
  url: {{base_url}}/usuarios/admins
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token_admin}}
}

body:json {
  {
    "documento": "8{{$timestamp}}",
    "apellido": "Test",
    "nombres": "Admin",
    "email": "admin{{$timestamp}}@test.com",
    "contrasenia": "test123"
  }
}

settings {
  encodeUrl: true
}
