meta {
  name: login_paciente
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "lopjac@correo.com",
    "contrasenia": "lopjac"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token_paciente", res.body.data.token);
  }
}

settings {
  encodeUrl: true
}
