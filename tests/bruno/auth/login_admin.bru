meta {
  name: login_admin
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "ferben@correo.com",
    "contrasenia": "ferben"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token_admin", res.body.data.token);
  }
}

settings {
  encodeUrl: true
}
